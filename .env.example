# Server
PORT=3001
NODE_ENV=production

# LLM (currently Google Gemini — change here and in LLM_MODEL to switch provider)
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=gemini-3.1-flash-lite

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/chatbot_db

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=contato@guilhermeruy.com.br
SMTP_PASS=your_smtp_password
SMTP_FROM="Chatbot <contato@guilhermeruy.com.br>"

# Email that receives new lead notifications
NOTIFICATION_EMAIL=contato@guilhermeruy.com.br

# Allowed origins (comma-separated)
ALLOWED_ORIGINS=example.com,www.example.com

# Message limit per session (LLM cost guardrail)
MAX_MESSAGES_PER_SESSION=20

# Admin panel
ADMIN_JWT_SECRET=your_random_secret_at_least_32_chars
ADMIN_EMAIL=contato@guilhermeruy.com.br
# ADMIN_PASSWORD — only needed the first time (npm run db:admin-migrate)
# ADMIN_PASSWORD=your_initial_password
