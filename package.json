{
  "name": "op-chatbot",
  "version": "1.0.0",
  "description": "Open source lead qualification chatbot",
  "scripts": {
    "dev": "concurrently \"tsx watch src/server.ts\" \"node scripts/build-widget.mjs --watch\"",
    "build:widget": "node scripts/build-widget.mjs",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:admin-migrate": "tsx src/db/admin_migrate.ts",
    "dev:admin": "cd admin && npm run dev",
    "build:admin": "cd admin && npm run build"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@google/generative-ai": "^0.21.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.29.1",
    "nodemailer": "^6.9.14",
    "pg": "^8.12.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.9",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.23.0",
    "tsx": "^4.15.7",
    "typescript": "^5.5.3"
  }
}
